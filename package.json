{
  "name": "sourcedraft",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source Git-based CMS for Markdown and MDX publishing.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter studio dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @sourcedraft/core --filter @sourcedraft/adapter-astro-mdx --filter @sourcedraft/adapter-markdown --filter @sourcedraft/github-publisher --filter studio test"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  },
  "keywords": [
    "cms",
    "markdown",
    "mdx",
    "astro",
    "static-site-generator",
    "git-based-cms"
  ],
  "license": "MIT"
}
