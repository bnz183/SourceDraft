# Use these in SourceDraft's .env when this Astro blog repo is your publish target.
# Copy to the SourceDraft workspace root — not into this example folder unless
# you run Studio with this directory as the working project.

SOURCEDRAFT_ADMIN_PASSWORD=
GITHUB_TOKEN=
GITHUB_OWNER=your-github-user
GITHUB_REPO=your-astro-blog
GITHUB_BRANCH=main
